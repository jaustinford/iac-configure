{
    "insecure-registries": [
        "{{ docker_hosts.host_1.networking.teine.ipv4 }}:{{ external_ports.nexus_docker_hosted }}",
        "{{ docker_hosts.host_1.networking.teine.ipv4 }}:{{ external_ports.nexus_docker_proxy }}",
        "{{ docker_hosts.host_2.networking.teine.ipv4 }}:{{ external_ports.nexus_docker_hosted }}",
        "{{ docker_hosts.host_2.networking.teine.ipv4 }}:{{ external_ports.nexus_docker_proxy }}",
        "{{ docker_hosts.host_1.networking.teine.fqdn }}:{{ external_ports.nexus_docker_hosted }}",
        "{{ docker_hosts.host_1.networking.teine.fqdn }}:{{ external_ports.nexus_docker_proxy }}",
        "{{ docker_hosts.host_2.networking.teine.fqdn }}:{{ external_ports.nexus_docker_hosted }}",
        "{{ docker_hosts.host_2.networking.teine.fqdn }}:{{ external_ports.nexus_docker_proxy }}"
    ],
    "log-driver": "json-file",
    "log-opts": {
        "max-size": "10m",
        "max-file": "5"
    }
}
