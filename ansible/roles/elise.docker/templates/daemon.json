{
  "insecure-registries": [
    "{{ docker01_vlan_40_address }}:{{ ports.nexus_docker_hosted }}",
    "{{ docker01_vlan_40_address }}:{{ ports.nexus_docker_proxy }}",
    "{{ docker02_vlan_40_address }}:{{ ports.nexus_docker_hosted }}",
    "{{ docker02_vlan_40_address }}:{{ ports.nexus_docker_proxy }}",
    "{{ docker01_vlan_40_fqdn }}:{{ ports.nexus_docker_hosted }}",
    "{{ docker01_vlan_40_fqdn }}:{{ ports.nexus_docker_proxy }}",
    "{{ docker02_vlan_40_fqdn }}:{{ ports.nexus_docker_hosted }}",
    "{{ docker02_vlan_40_fqdn }}:{{ ports.nexus_docker_proxy }}",
    "docker-hosted.proxy-int.{{ lab.domain }}",
    "docker-proxy.proxy-int.{{ lab.domain }}"
  ],
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "10m",
    "max-file": "5"
  }
}
