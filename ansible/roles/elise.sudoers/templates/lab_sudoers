{% set docker_restrictions = [] %}
{% for cmd_path in sudoers.restrict_groups.cmd_paths %}
{% for docker_option in sudoers.restrict_groups.docker_options %}
{{- docker_restrictions.append(cmd_path + "/docker " + docker_option + " *") -}}
{{- docker_restrictions.append(cmd_path + "/docker * " + docker_option + " *") -}}
{% endfor %}
{% endfor %}
{% set filesystem_restrictions = [] %}
{% for cmd_path in sudoers.restrict_groups.cmd_paths %}
{% for discover_cmd in sudoers.restrict_groups.discover_cmds %}
{% for discover_dir in sudoers.restrict_groups.discover_dirs %}
{{- filesystem_restrictions.append(cmd_path + "/" + discover_cmd + " " + discover_dir + "*") -}}
{{- filesystem_restrictions.append(cmd_path + "/" + discover_cmd + " * " + discover_dir + "*") -}}
{% endfor %}
{% endfor %}
{% endfor %}
Cmnd_Alias RESTRICT_ESCALATE = \ 
/usr/bin/su, \ 
/usr/bin/passwd

Cmnd_Alias RESTRICT_DOCKER = \
{% for docker_restriction in docker_restrictions %}
{{ docker_restriction }}{% if not loop.last %}, \
{% else %}

{% endif %}
{% endfor %}

Cmnd_Alias RESTRICT_FILESYSTEM = \
{% for filesystem_restriction in filesystem_restrictions %}
{{ filesystem_restriction }}{% if not loop.last %}, \
{% else %}

{% endif %}
{% endfor %}

User_Alias LAB_SUDOERS = \
{{ names.lab_users.privileged }}

LAB_SUDOERS ALL=(ALL) ALL, \
    !RESTRICT_ESCALATE, \
    !RESTRICT_DOCKER, \
    !RESTRICT_FILESYSTEM
