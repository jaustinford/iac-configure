############################################################
# CMDS_FS_RESTRICTED
############################################################

{% set cmds_fs_restricteds = [] %}
{%- for cmd_path in sudoers.cmd_paths -%}
{%- for cmds_fs_restricted in sudoers.aliases.cmds.fs_restricted -%}
{%- for dirs_fs_restricted in sudoers.aliases.dirs.fs_restricted -%}
