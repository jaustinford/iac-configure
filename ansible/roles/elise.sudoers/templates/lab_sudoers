{%- endfor %}

############################################################
# GROUP ASSIGNMENTS
############################################################

LAB_SUDOERS ALL=(ALL) ALL, \
    NOPASSWD: CMDS_GENERAL_NOPASSWD, \
    NOPASSWD: CMDS_DOCKER_NOPASSWD, \
    !CMDS_GENERAL_RESTRICTED, \
    !CMDS_DOCKER_RESTRICTED, \
    !CMDS_FS_RESTRICTED
