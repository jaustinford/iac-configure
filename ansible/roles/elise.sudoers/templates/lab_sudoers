{% set cmds_docker_nopasswds = [] %}
{%- for cmd_path in sudoers.cmd_paths -%}
{%- for docker_nopasswd in sudoers.aliases.cmds.docker_nopasswd -%}
{{- cmds_docker_nopasswds.append(cmd_path + "/docker " + docker_nopasswd) -}}
{{- cmds_docker_nopasswds.append(cmd_path + "/docker " + docker_nopasswd + " *") -}}
{{- cmds_docker_nopasswds.append(cmd_path + "/docker * " + docker_nopasswd) -}}
{{- cmds_docker_nopasswds.append(cmd_path + "/docker * " + docker_nopasswd + " *") -}}
{%- endfor -%}
{%- endfor -%}

Cmnd_Alias CMDS_DOCKER_NOPASSWD = \
{% for cmds_docker_nopasswd in cmds_docker_nopasswds -%}
{{- cmds_docker_nopasswd -}}{% if not loop.last %}, \
{% else %}

{% endif %}
{%- endfor %}

