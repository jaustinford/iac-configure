
############################################################
# LAB_SUDOERS
############################################################

User_Alias LAB_SUDOERS = \
{% for lab_sudoer in sudoers.aliases.users.lab_sudoers -%}
{{- lab_sudoer -}}{% if not loop.last %}, \
{% else %}

{% endif %}
{%- endfor %}

############################################################
# CMDS_GENERAL_NOPASSWD
############################################################

{% set cmds_general_nopasswds = [] %}
{%- for cmd_path in sudoers.cmd_paths -%}
{%- for general_nopasswd in sudoers.aliases.cmds.general_nopasswd -%}
{{- cmds_general_nopasswds.append(cmd_path + "/" + general_nopasswd) -}}
{%- endfor -%}
{%- endfor -%}

Cmnd_Alias CMDS_GENERAL_NOPASSWD = \
{% for cmds_general_nopasswd in cmds_general_nopasswds -%}
{{- cmds_general_nopasswd -}}{% if not loop.last %}, \
{% else %}

{% endif %}
{%- endfor %}

############################################################
# CMDS_DOCKER_NOPASSWD
